# Copia este archivo como .env.local y ajusta los valores reales.
CONTACT_EMAIL_ENABLED=true
CONTACT_EMAIL_TO=hola@nuukestudio.com
CONTACT_EMAIL_FROM=hola@nuukestudio.com
CONTACT_EMAIL_SUBJECT_PREFIX=Muebles Arte

# SMTP con TLS directo suele usar 465. Para STARTTLS usa 587 y SMTP_SECURE=false.
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=usuario@example.com
SMTP_PASS=app-password-o-clave-smtp
SMTP_HELO_NAME=localhost
SMTP_REJECT_UNAUTHORIZED=true
SMTP_TIMEOUT_MS=15000
SMTP_FAMILY=4
